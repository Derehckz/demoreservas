{
  "name": "mis-reservas",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --testPathPattern=tests/",
    "sync-config": "node scripts/sync-config.js",
    "dev": "netlify dev",
    "dev:build": "npm run build && netlify dev",
    "dev:test": "dotenv -e .env.test -- npx netlify dev",
    "dev:watch": "concurrently \"npm run build:watch:dashboard\" \"npm run build:watch:reserva\" \"npm run dev\"",
    "build": "npm run build:tailwind && npm run build:dashboard && npm run build:reserva",
    "generate-icons": "node scripts/generate-icons.js",
    "build:tailwind": "npx tailwindcss -i ./css/tailwind.input.css -o ./css/tailwind.css --minify",
    "build:dashboard": "npx esbuild js/dashboard.js --bundle --outfile=js/dashboard.bundle.js --loader:.js=jsx --format=iife --banner:js=\"var React=window.React,ReactDOM=window.ReactDOM;\"",
    "build:reserva": "npx esbuild js/reserva.js --bundle --outfile=js/reserva.bundle.js --loader:.js=jsx --format=iife --banner:js=\"var React=window.React,ReactDOM=window.ReactDOM;\"",
    "build:watch:dashboard": "npx esbuild js/dashboard.js --bundle --outfile=js/dashboard.bundle.js --loader:.js=jsx --format=iife --banner:js=\"var React=window.React,ReactDOM=window.ReactDOM;\" --watch",
    "build:watch:reserva": "npx esbuild js/reserva.js --bundle --outfile=js/reserva.bundle.js --loader:.js=jsx --format=iife --banner:js=\"var React=window.React,ReactDOM=window.ReactDOM;\" --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@netlify/neon": "^0.1.2",
    "pg": "^8.18.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^7.4.2",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19"
  }
}
