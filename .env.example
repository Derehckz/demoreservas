# Copia este archivo como .env y completa los valores.
# .env nunca debe subirse a git.

# Conexión a Neon PostgreSQL
# Obtener la URL en: https://console.neon.tech
NETLIFY_DATABASE_URL=postgresql://usuario:contraseña@host/neondb?sslmode=require

# Contraseña del panel de administración
# En producción (Netlify): Site → Environment variables
LOGIN_PASSWORD=tu_contraseña_segura

# Claves VAPID para notificaciones push
# Generar con: npm run generate-vapid (o npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Secret para autorizar el cron de alertas programadas
# Generar con: openssl rand -hex 32
# Configurar también en Netlify y en el webhook/cron que llame a enviaralertas
CRON_SECRET=
